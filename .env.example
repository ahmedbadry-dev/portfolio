# ------------------------------
# Public site URL / SEO
# ------------------------------
# Required in production for canonical URLs, sitemap, and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------
# Convex
# ------------------------------
# Public/client Convex URL (used by Convex React client and public reads).
NEXT_PUBLIC_CONVEX_URL=

# Server Convex URL.
# Not required for admin/projects/analytics in current code because those paths
# can fall back to NEXT_PUBLIC_CONVEX_URL.
# Still recommended to set explicitly for server-side consistency.
# Note: app/api/contact currently writes to Convex only when CONVEX_URL is set.
CONVEX_URL=

# Required for protected server-side mutations to Convex
# (admin project CRUD, admin submissions actions, analytics writes/reads).
CONVEX_ADMIN_MUTATION_KEY=

# Public projects read source strategy.
# local  = local dataset only
# convex = Convex-first with local fallback when Convex read fails
# auto   = same behavior as convex in current implementation
PROJECTS_READ_SOURCE=auto

# Optional analytics dedupe cooldown in seconds (default: 60)
ANALYTICS_VIEW_COOLDOWN_SECONDS=60

# ------------------------------
# Admin auth
# ------------------------------
# SHA-256 hex hash of your admin password.
ADMIN_PASSWORD_HASH=

# Random long secret for admin session signing.
ADMIN_SESSION_SECRET=

# ------------------------------
# Contact email
# ------------------------------
RESEND_API_KEY=

# Optional social metadata
NEXT_PUBLIC_TWITTER_HANDLE=
